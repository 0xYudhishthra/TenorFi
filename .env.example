# Copy to .env and fill in. NEVER commit the real .env.

# --- RPC endpoints ---
# Base mainnet (chain id 8453). Deploy.s.sol broadcasts here — real funds/gas.
BASE_RPC_URL=

# --- deployer (use a throwaway hackathon key; never a real one) ---
# Prefer `cast wallet`/keystore over a raw private key in env.
# Deploy.s.sol reads PRIVATE_KEY.
PRIVATE_KEY=

# --- Chainlink CRE ---
# Hyperliquid funding endpoint the CRE workflow reads (public API, no key needed).
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
# CRE config for Base mainnet (chain name + selector for project.yaml / EVM client):
#   chain name     = ethereum-mainnet-base-1
#   chain selector = 15971525489660198786
# Production KeystoneForwarder that delivers DON reports to KeelFundingReceiver.onReport.
# Deploy.s.sol reads CRE_FORWARDER. For `cre workflow simulate`, deploy/rotate to the Base
# MockKeystoneForwarder 0x5e342a8438b4f5d39e72875fcee6f76b39cce548 instead, then setForwarder() back.
CRE_FORWARDER=0xF8344CFd5c43616a4366C34E3EEE75af79a74482
# EOA fallback authorized on KeelFundingReceiver to post reports if the DON is flaky.
RELAYER=

# --- contract addresses (filled after deploy) ---
KEEL_SWAP_ADDRESS=
FUNDING_INDEX_ADDRESS=
KEEL_FUNDING_RECEIVER_ADDRESS=
USDC_ADDRESS=
