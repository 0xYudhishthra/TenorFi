# TenorFi web — environment example. Copy to .env.local for local dev.
# Do NOT commit a real .env.

# Base URL of the keel-api backend (Hono server, default port 8080).
# The web app reads live funding, positions, and hedge quotes from here, and
# falls back to bundled mock data if it is unreachable.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Reown AppKit / WalletConnect project ID — required for the wallet "Connect"
# button (opens the AppKit modal: MetaMask injected + WalletConnect QR/mobile).
# Get a free one at https://cloud.reown.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
