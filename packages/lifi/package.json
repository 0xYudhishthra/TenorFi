{
  "name": "@keel/lifi",
  "version": "0.0.1",
  "description": "LI.FI Composer orchestrator for Keel — cross-chain deposit into HyperCore + contract-call to open the swap.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "validate:deposit": "node --import tsx scripts/validate-deposit.ts"
  },
  "dependencies": {
    "@lifi/sdk": "^4.0.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
