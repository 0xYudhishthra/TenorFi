{
  "name": "@keel/lifi",
  "version": "0.0.1",
  "description": "LI.FI Composer orchestrator for Keel — one Composer flow opens the Keel swap on Base, a second bridges perp margin toward Hyperliquid.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "validate:composer": "node --import tsx scripts/validate-composer.ts"
  },
  "dependencies": {
    "@lifi/compose-spec": "^0.1.0",
    "@lifi/composer-sdk": "^0.1.0",
    "@lifi/sdk": "^4.0.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
