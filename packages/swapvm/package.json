{
  "name": "@keel/swapvm",
  "version": "0.0.1",
  "description": "Keel's custom SwapVM instruction (_fundingSettle) — funding-rate swap as an Aqua app",
  "license": "MIT",
  "scripts": {
    "precompile": "mkdir -p node_modules/forge-std && rsync -a node_modules/forge-std/src/ node_modules/forge-std/ 2>/dev/null || true",
    "build": "npm run precompile && hardhat compile",
    "test": "npm run precompile && hardhat test"
  },
  "dependencies": {
    "@1inch/solidity-utils": "^6.8.0",
    "@1inch/aqua": "https://github.com/1inch/aqua",
    "@1inch/swap-vm": "https://github.com/1inch/swap-vm#0.0.4",
    "@openzeppelin/contracts": "^5.4.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.15.0",
    "hardhat": "^2.22.15",
    "hardhat-dependency-compiler": "^1.2.1",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "elliptic": "6.6.1"
  }
}
